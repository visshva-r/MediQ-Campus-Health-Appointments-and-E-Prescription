// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * ---------------------------
 * Auth / Users (NextAuth)
 * ----------------------------
 */

enum Role {
  STUDENT
  DOCTOR
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())

  // Relations
  accounts     Account[]
  sessions     Session[]
  appointments Appointment[]
  orders       Order[] // reserved for optional e-commerce; harmless if unused
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/**
 * ---------------------------
 * MediQ domain models
 * ----------------------------
 */

model Doctor {
  id           String        @id @default(cuid())
  name         String
  specialty    String
  bio          String?
  room         String?
  active       Boolean       @default(true)
  slots        Slot[]
  appointments Appointment[]
  createdAt    DateTime      @default(now())
}

model Slot {
  id          String   @id @default(cuid())
  doctorId    String
  start       DateTime
  end         DateTime
  capacity    Int      @default(1)
  bookedCount Int      @default(0)

  doctor       Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([doctorId, start])
}

model Appointment {
  id              String     @id @default(cuid())
  userId          String
  doctorId        String
  slotId          String
  reason          String?
  status          ApptStatus @default(PENDING)
  prescriptionUrl String?
  createdAt       DateTime   @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  slot   Slot   @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([doctorId, createdAt])
}

enum ApptStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

/**
 * ---------------------------
 * (Optional) Simple commerce placeholders
 * - harmless to keep; you can ignore
 * ----------------------------
 */

model Product {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  price       Int // paise
  description String?
  imageUrl    String?
  stock       Int         @default(0)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  OrderItem   OrderItem[]
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  total     Int
  status    OrderStatus @default(PENDING)
  items     OrderItem[]
  paymentId String?
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  qty       Int    @default(1)
  price     Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  FULFILLED
}
